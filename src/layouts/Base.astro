---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "$config";
import App from "$layouts/App.astro";
import Navigator from "$layouts/header/Navigator.svelte";
import Footer from "$layouts/Footer.astro";
import Tip from "$components/Tip.svelte";
import "$styles/tailwind.css";
import "$styles/global.css";
import "$styles/markdown.css";
import "medium-zoom/dist/style.css";
import "katex/dist/katex.min.css";

let route = Astro.url.pathname;

const {
	locale = config.i18n.defaultLocale,
	title: subtitle,
	description = config.description,
	series,
	article,
	openGraph: openGraphOverride,
	twitter: twitterOverride
} = Astro.props;
const title = config.title;
---

<script>
	import zoom from "medium-zoom/dist/pure";
	import Time from "$utils/time";

	const localizeTimes = () => document.querySelectorAll("time").forEach(time => time.dateTime && (time.title = Time.locale(time.dateTime, navigator.language, Time.userTimezone)));

	window.zoom = () => zoom(".markdown img:not([data-nozoom])", { background: "#00000044" });

	function syncBodySeries() {
		const el = document.querySelector("main [data-series]");
		const value = el?.getAttribute("data-series");
		if (value) {
			document.body.dataset.series = value;
		} else {
			delete document.body.dataset.series;
		}
	}

	let bingoInteractionBound = false;

	function initBingoCardSelection() {
		document.querySelectorAll(".markdown .bingo-card").forEach(card => {
			card.setAttribute("tabindex", "0");
		});
		if (bingoInteractionBound) return;
		bingoInteractionBound = true;
		document.addEventListener("click", e => {
			const card = e.target instanceof Element ? e.target.closest(".markdown .bingo-card") : null;
			if (!card) return;
			card.classList.toggle("selected");
		});
		document.addEventListener("keydown", e => {
			if (e.key !== "Enter" && e.key !== " ") return;
			const card = e.target instanceof Element ? e.target.closest(".markdown .bingo-card") : null;
			if (!card || card !== document.activeElement) return;
			e.preventDefault();
			card.classList.toggle("selected");
		});
	}

	function initialize() {
		syncBodySeries();
		localizeTimes();
		window.zoom();
		initBingoCardSelection();
	}

	initialize();

	document.addEventListener("astro:page-load", initialize);

	if (typeof window !== "undefined" && window.swup) {
		window.swup.hooks.on("page:load", syncBodySeries);
	}
	document.addEventListener("swup:enable", () => window.swup?.hooks.on("page:load", syncBodySeries));
</script>

<App
	{title}
	{subtitle}
	{description}
	{series}
	{article}
	author={config.author.name}
	openGraphOverride={openGraphOverride}
	twitterOverride={twitterOverride}
>
	<Tip client:load />
	<Navigator {locale} {route} client:load />

	<div id="body" style="min-height: calc(100vh - 60px);">
		<slot />
	</div>

	<Footer {locale} author={config.author} copyright={config.copyright} />
</App>
