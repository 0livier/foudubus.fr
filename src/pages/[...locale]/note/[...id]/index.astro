---
import { getCollection, render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import config, { monolocale } from "$config";
import Base from "$layouts/Base.astro";
import TOC from "$components/TOC.astro";
import Sensitive from "$components/Sensitive.svelte";
import ReadingBar from "$components/ReadingBar.svelte";
import Position from "$components/Position.astro";
import { tagSlug } from "$utils/slug";
import { canonicalPath, canonicalPagePath } from "$utils/canonical-url";

export async function getStaticPaths() {
	const notes = await getCollection("note", note => !note.data.draft);

	function toRoute(note: { id: string }) {
		if (monolocale) {
			return { locale: undefined as string | undefined, id: note.id };
		}
		const [language, ...ids] = note.id.split("/");
		const locale = config.i18n.defaultLocale === language ? undefined : language;
		const id = ids.join("/");
		return { locale, id };
	}

	const byLocale = new Map<string | undefined, typeof notes>();
	for (const note of notes) {
		const { locale } = toRoute(note);
		if (!byLocale.has(locale)) byLocale.set(locale, []);
		byLocale.get(locale)!.push(note);
	}
	const seriesChains = new Map<string, { prev: { id: string; title: string } | null; next: { id: string; title: string } | null }>();
	for (const [, localeNotes] of byLocale) {
		const bySeries = new Map<string, typeof notes>();
		for (const note of localeNotes) {
			const series = note.data.series;
			if (!series) continue;
			if (!bySeries.has(series)) bySeries.set(series, []);
			bySeries.get(series)!.push(note);
		}
		for (const [, seriesNotes] of bySeries) {
			const sorted = [...seriesNotes].sort((a, b) => {
				const t = a.data.timestamp.getTime() - b.data.timestamp.getTime();
				if (t !== 0) return t;
				return (b.data.top ?? 0) - (a.data.top ?? 0);
			});
			for (let i = 0; i < sorted.length; i++) {
				const note = sorted[i];
				const prev = i > 0 ? { id: toRoute(sorted[i - 1]).id, title: sorted[i - 1].data.title } : null;
				const next = i < sorted.length - 1 ? { id: toRoute(sorted[i + 1]).id, title: sorted[i + 1].data.title } : null;
				seriesChains.set(`${note.id}`, { prev, next });
			}
		}
	}

	return notes.map(note => {
		const { locale, id } = toRoute(note);
		const seriesNav = note.data.series ? seriesChains.get(note.id) ?? { prev: null, next: null } : { prev: null, next: null };
		return { params: { locale, id }, props: { note, ...seriesNav } };
	});
}

const { locale = config.i18n.defaultLocale } = Astro.params;
const { note, prev, next } = Astro.props;

const { Content, headings, remarkPluginFrontmatter: frontmatter } = await render(note);

const canonicalPathname = canonicalPath(Astro.url.pathname);
const articleCanonicalUrl = new URL(canonicalPathname, Astro.site);
const articleImageUrl = new URL(`${canonicalPathname}/graph.png`, Astro.site);

function noteLine(note: any): string {
  if (note.data.series === "Lavande") return "L";
  if (note.data.series) return note.data.series.charAt(0).toUpperCase();
  return String(new Date(note.data.timestamp).getDate()).padStart(2, "0");
}
function dateShort(d: Date): string {
  const dt = new Date(d);
  return `${String(dt.getDate()).padStart(2, "0")}.${String(dt.getMonth() + 1).padStart(2, "0")}`;
}
const STICKER_COLORS = ["ticket", "bordeaux", "municipal", "warning", "ink"] as const;
function stickerColor(tag: string, i: number): string {
  const t = tag.toLowerCase();
  if (t.includes("fiction") || t.includes("nouvelle")) return "ink";
  if (t.includes("recette")) return "ticket";
  if (t.includes("communication")) return "municipal";
  return STICKER_COLORS[i % STICKER_COLORS.length];
}

const line = noteLine(note);
const ds = dateShort(note.data.timestamp);
const notesHref = getRelativeLocaleUrl(locale, canonicalPagePath("/note"));
---

<Base
  title={note.data.title}
  {locale}
  description={note.data.description ?? ""}
  series={note.data.series}
  article={{
    timestamp: note.data.timestamp,
    section: note.data.series,
    tags: note.data.tags,
    mainEntityOfPage: articleCanonicalUrl.toString(),
    image: articleImageUrl.toString()
  }}
  openGraph={note.data.openGraph}
  twitter={note.data.twitter}
>
  <ReadingBar client:load />

  <main style="padding: 52px 48px 0; max-width: 820px; margin: 0 auto;">
    <!-- Back link -->
    <a href={notesHref} style="
      display: inline-flex; align-items: center; gap: 6px;
      font-family: var(--mono-fd); font-size: 10px;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: var(--primary-color); opacity: 0.6;
      text-decoration: none; margin-bottom: 36px;
    ">← retour aux écrits</a>

    <!-- Title block -->
    <header style="margin-bottom: 40px;">
      <!-- Meta line -->
      <div style="
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        margin-bottom: 18px;
      ">
        <span style="
          background: var(--accent-color); color: var(--background-color);
          font-family: var(--bebas); font-size: 16px; padding: 2px 8px;
          letter-spacing: 0.08em;
        ">L.{line}</span>
        {note.data.series && (
          <span style="
            font-family: var(--mono-fd); font-size: 10px;
            letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.65;
          ">{note.data.series}</span>
        )}
        <span style="
          font-family: var(--mono-fd); font-size: 10px;
          letter-spacing: 0.12em; opacity: 0.5;
        ">{frontmatter.words} mots</span>
      </div>

      <!-- H1 -->
      <h1 style="
        font-family: var(--serif-display); font-style: italic;
        font-size: clamp(40px, 7vw, 72px); font-weight: 500;
        line-height: 1; margin: 0 0 20px;
        color: var(--primary-color);
      ">{note.data.title}</h1>

      <!-- Date + tags row -->
      <div style="
        display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
        margin-bottom: 14px;
      ">
        <span class="stamp stamp-strong" style="transform: rotate(-1.5deg);">{ds}</span>
        <span style="
          font-family: var(--mono-fd); font-size: 9px;
          letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.5;
        ">{note.data.timestamp.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' }).toUpperCase()}</span>
      </div>

      {note.data.tags && note.data.tags.length > 0 && (
        <div style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 20px;">
          {note.data.tags.map((tag: string, ti: number) => (
            <a
              href={getRelativeLocaleUrl(locale, canonicalPagePath(`/tag/${tagSlug(tag)}`))}
              class={`sticker sticker-${stickerColor(tag, ti)} angle-${(ti % 4) + 1}`}
              style="text-decoration: none;"
            >
              <span style="opacity:0.7;font-size:9px;margin-right:1px;">#</span>{tag.toLowerCase()}
            </a>
          ))}
        </div>
      )}

      <div style="
        border-top: 1px dashed color-mix(in srgb, var(--primary-color) 22%, transparent);
        padding-top: 14px;
        display: flex; align-items: center; gap: 14px;
      ">
        <div class="halftone" style="width: 40px; height: 10px; opacity: 0.4;"></div>
        <div style="flex: 1; height: 1px; background: color-mix(in srgb, var(--primary-color) 10%, transparent);"></div>
      </div>
    </header>

    <!-- Article body -->
    <Sensitive {locale} back="/note" sensitive={note.data.sensitive} client:load>
      <div style="display: flex; gap: 40px; align-items: flex-start;">
        <section id="markdown-content" class="markdown article-body" style="flex: 1; min-width: 0;">
          <Content />
        </section>
        {note.data.toc && (
          <aside style="
            display: none; flex-shrink: 0; width: 180px;
          " class="toc-aside">
            <div style="position: sticky; top: 80px;">
              <div style="
                font-family: var(--mono-fd); font-size: 10px;
                letter-spacing: 0.16em; text-transform: uppercase;
                opacity: 0.6; margin-bottom: 10px;
              ">sommaire</div>
              <nav>
                <TOC {headings} />
              </nav>
            </div>
          </aside>
        )}
      </div>
    </Sensitive>

    <!-- End ornament -->
    <div style="
      text-align: center; margin: 40px 0;
      font-family: var(--serif-display); font-size: 20px;
      color: var(--accent-color); letter-spacing: 0.4em;
      opacity: 0.7;
    ">◆ — fin — ◆</div>

    <!-- Composté bar -->
    <div style="
      border: 1px dashed color-mix(in srgb, var(--primary-color) 25%, transparent);
      padding: 12px 18px;
      display: flex; justify-content: space-between; align-items: center;
      font-family: var(--mono-fd); font-size: 10px;
      letter-spacing: 0.12em; text-transform: uppercase;
      opacity: 0.65; margin-bottom: 40px;
    ">
      <span>éditions du fou du bus · {ds}</span>
      <span class="stamp stamp-strong" style="transform: rotate(-2deg); opacity: 0.8;">composté</span>
    </div>

    <!-- Prev / Next navigation -->
    {note.data.series && (prev || next) && (
      <nav style="
        display: flex; justify-content: space-between; align-items: center;
        gap: 20px; flex-wrap: wrap;
        border-top: 2px solid color-mix(in srgb, var(--primary-color) 15%, transparent);
        padding-top: 24px; margin-bottom: 48px;
      ">
        {prev ? (
          <a href={getRelativeLocaleUrl(locale, canonicalPagePath(`/note/${prev.id}`))} style="
            font-family: var(--mono-fd); font-size: 11px;
            letter-spacing: 0.14em; text-transform: uppercase;
            color: var(--primary-color); opacity: 0.7; text-decoration: none;
            display: flex; flex-direction: column; gap: 4px; max-width: 240px;
          ">
            <span style="color: var(--ticket);">← arrêt précédent</span>
            <span style="font-family: var(--serif-display); font-style: italic; font-size: 18px; font-weight: 500; opacity: 1; letter-spacing: 0;">{prev.title}</span>
          </a>
        ) : <span />}
        {next ? (
          <a href={getRelativeLocaleUrl(locale, canonicalPagePath(`/note/${next.id}`))} style="
            font-family: var(--mono-fd); font-size: 11px;
            letter-spacing: 0.14em; text-transform: uppercase;
            color: var(--primary-color); opacity: 0.7; text-decoration: none;
            display: flex; flex-direction: column; align-items: flex-end; gap: 4px; max-width: 240px;
          ">
            <span style="color: var(--ticket);">prochain arrêt →</span>
            <span style="font-family: var(--serif-display); font-style: italic; font-size: 18px; font-weight: 500; opacity: 1; letter-spacing: 0; text-align: right;">{next.title}</span>
          </a>
        ) : <span />}
      </nav>
    )}

    <Position {locale} />
  </main>
</Base>

<style>
  @media (min-width: 700px) {
    .toc-aside { display: block !important; }
  }
  @media (max-width: 639px) {
    main { padding-left: 16px !important; padding-right: 16px !important; }
  }
</style>
