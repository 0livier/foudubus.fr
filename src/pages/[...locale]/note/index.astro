---
import { getCollection } from "astro:content";
import config, { monolocale } from "$config";
import Base from "$layouts/Base.astro";
import Note from "$components/Note.svelte";

export async function getStaticPaths() {
	return config.i18n.locales.map(locale => ({ params: { locale: config.i18n.defaultLocale === locale ? undefined : locale } }));
}

const { locale = config.i18n.defaultLocale } = Astro.params;

const notes = await getCollection("note", note => {
	let published = !note.data.draft;
	let localed = monolocale || note.id.split("/")[0] === locale;
	return published && localed;
});

let list = notes.map(note => ({
	id: note.id,
	data: {
		title: note.data.title,
		timestamp: note.data.timestamp,
		series: note.data.series,
		tags: note.data.tags,
		sensitive: note.data.sensitive,
		top: note.data.top
	}
}));

const series = Array.from(
	new Set(notes.map(note => note.data.series).filter((s): s is string => typeof s === "string"))
).sort();
const tags = Array.from(new Set(notes.flatMap(note => note.data.tags ?? []))).sort();
---

<Base title="Écrits" {locale}>
  <main style="padding: 52px 48px 0;">
    <!-- Plan du réseau header -->
    <div style="margin-bottom: 8px;">
      <div style="
        font-family: var(--mono-fd); font-size: 11px;
        letter-spacing: 0.22em; text-transform: uppercase; opacity: 0.6;
        margin-bottom: 10px;
      ">⌬ RÉSEAU&nbsp;&nbsp;/&nbsp;&nbsp;LIGNE ÉDITIONS&nbsp;&nbsp;/&nbsp;&nbsp;{notes.length} ARRÊTS</div>
      <h1 style="
        font-family: var(--serif-display); font-style: italic;
        font-size: clamp(48px, 8vw, 80px); font-weight: 500;
        line-height: 0.9; margin: 0 0 6px; color: var(--primary-color);
      ">Plan du réseau</h1>
      <div style="
        font-family: var(--hand); font-size: 22px;
        color: var(--bordeaux); transform: rotate(-1deg);
        display: inline-block;
      ">tous les écrits, dans l'ordre de passage →</div>
    </div>

    <!-- Route line decoration -->
    <div style="
      display: flex; align-items: center; gap: 14px;
      margin: 24px 0 36px;
    ">
      <div class="route-line-h" style="flex: 1; height: 4px; color: var(--ticket);"></div>
      <div class="halftone" style="width: 50px; height: 14px; opacity: 0.5;"></div>
      <div class="route-line-h" style="flex: 1; height: 4px; color: var(--bordeaux);"></div>
    </div>

    <Note client:load {locale} notes={list} {series} {tags} />
  </main>
</Base>

<style>
  @media (max-width: 639px) {
    main { padding-left: 16px !important; padding-right: 16px !important; }
  }
</style>
